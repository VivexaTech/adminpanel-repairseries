rules_version = '2';

// Deploy: firebase deploy --only firestore:rules
//
// Bootstrap: Create the first Super Admin manually in Firestore:
//   Collection: adminUsers
//   Document ID: <Firebase Auth UID of your admin>
//   Fields: name, email, role: "superAdmin", status: "active", createdAt (timestamp)

service cloud.firestore {
  match /databases/{database}/documents {

    function authed() {
      return request.auth != null;
    }

    function adminProfile() {
      return get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data;
    }

    function isActiveAdmin() {
      return authed() && adminProfile().status == 'active';
    }

    function role() {
      return adminProfile().role;
    }

    function isSuperAdmin() {
      return isActiveAdmin() && role() == 'superAdmin';
    }

    function isTechnicianManager() {
      return isActiveAdmin() && role() == 'technicianManager';
    }

    function isBookingManager() {
      return isActiveAdmin() && role() == 'bookingManager';
    }

    function isServiceManager() {
      return isActiveAdmin() && role() == 'serviceManager';
    }

    // Technician mobile app: `technicians/{docId}` doc id should match Firebase Auth uid
    // (or align your tech app with however you store `booking.technicianId`).
    function isTechnicianActor() {
      return request.auth != null
        && exists(/databases/$(database)/documents/technicians/$(request.auth.uid));
    }

    function technicianOwnsBookingData(booking) {
      return isTechnicianActor() && booking.technicianId == request.auth.uid;
    }

    function customerOwnsBooking(booking) {
      return authed() && booking.customerId == request.auth.uid;
    }

    function technicianApprovalRequestPatchOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'addOnApprovalRequest',
        'updatedAt',
      ]);
    }

    // Customer user app: Approve / reject add-on batch (must match booking math in app or Cloud Function).
    function customerAddOnDecisionPatchOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'addOnServices',
        'addOnApprovalRequest',
        'originalBookingAmount',
        'addedServicesAmount',
        'finalBookingAmount',
        'platformFeeAmount',
        'addonFeeAmount',
        'totalDeduction',
        'technicianFinalEarning',
        'totalAmount',
        'finalAmount',
        'technicianEarning',
        'platformCommission',
        'updatedAt',
      ]);
    }

    match /adminUsers/{userId} {
      allow read: if authed() && (
        request.auth.uid == userId ||
        isSuperAdmin()
      );
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    match /customers/{docId} {
      allow read: if isSuperAdmin() || isBookingManager();
      allow write: if isSuperAdmin();
    }

    match /technicians/{docId} {
      allow read: if isSuperAdmin() || isBookingManager() || isTechnicianManager();
      allow write: if isSuperAdmin() || isTechnicianManager();
    }

    match /technicians/{techId}/busySlots/{slotId} {
      allow read: if isSuperAdmin() || isBookingManager() || isTechnicianManager();
      allow write: if isSuperAdmin() || isBookingManager() || isTechnicianManager();
    }

    match /technicians/{techId}/transactions/{txId} {
      allow read: if isSuperAdmin() || isBookingManager() || isTechnicianManager()
        || (isTechnicianActor() && request.auth.uid == techId);
      allow create: if isSuperAdmin() || isBookingManager() || isTechnicianManager();
      allow update, delete: if false;
    }

    match /bookings/{docId} {
      allow read: if isSuperAdmin() || isBookingManager() || isTechnicianManager()
        || technicianOwnsBookingData(resource.data);
      allow create: if isSuperAdmin() || isBookingManager();
      allow update: if isSuperAdmin() || isBookingManager()
        || (technicianOwnsBookingData(resource.data)
            && request.resource.data.technicianId == resource.data.technicianId
            && request.resource.data.customerId == resource.data.customerId
            && technicianApprovalRequestPatchOnly())
        || (customerOwnsBooking(resource.data)
            && request.resource.data.technicianId == resource.data.technicianId
            && request.resource.data.customerId == resource.data.customerId
            && customerAddOnDecisionPatchOnly());
      allow delete: if isSuperAdmin() || isBookingManager();
    }

    match /services/{docId} {
      allow read: if isSuperAdmin() || isBookingManager() || isServiceManager();
      allow write: if isSuperAdmin() || isServiceManager();
    }

    match /categories/{docId} {
      allow read: if isSuperAdmin() || isBookingManager() || isServiceManager() || isTechnicianActor();
      allow write: if isSuperAdmin() || isServiceManager();
    }

    // Technician-only catalog (not customer-facing services). Filter by `categoryId` in app.
    match /additionalServices/{docId} {
      allow read: if isSuperAdmin() || isBookingManager() || isServiceManager() || isTechnicianActor();
      allow write: if isSuperAdmin() || isServiceManager();
    }

    // Queued by admin panel; Cloud Function sends FCM (admin SDK bypasses these rules).
    match /bookingNotificationOutbox/{docId} {
      allow create: if isSuperAdmin() || isBookingManager();
      allow read, update, delete: if false;
    }

    match /faqs/{docId} {
      allow read: if isSuperAdmin() || isBookingManager() || isServiceManager();
      allow write: if isSuperAdmin() || isServiceManager();
    }

    match /offers/{docId} {
      allow read: if isSuperAdmin() || isBookingManager() || isServiceManager();
      allow write: if isSuperAdmin() || isServiceManager();
    }

    match /coupons/{docId} {
      allow read: if isSuperAdmin() || isBookingManager() || isServiceManager();
      allow write: if isSuperAdmin() || isServiceManager();
    }

    match /settings/{docId} {
      allow read: if isActiveAdmin();
      allow write: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
